# Frontend Environment Variables
VITE_API_URL=http://localhost:5000
VITE_APP_NAME=Online Voting System
VITE_APP_VERSION=1.0.0

# Backend Environment Variables
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voting_system

# JWT Secrets
JWT_ACCESS_SECRET=your_access_token_secret_key_min_32_characters
JWT_REFRESH_SECRET=your_refresh_token_secret_key_min_32_characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@votingsystem.com
SMTP_FROM_NAME=Online Voting System

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Cors
CORS_ORIGIN=http://localhost:5173

# Redis (Optional for caching)
REDIS_URL=redis://localhost:6379

# Socket.IO
SOCKET_IO_CORS=http://localhost:5173
